---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import CallToAction from '../components/CallToAction.astro';
import { SITE } from '../consts';

const values = [
  { title: 'Craft', body: 'We care about the details that users never see but always feel — the tests, the names, the edges.' },
  { title: 'Candor', body: 'We tell you what we actually think, early, even when it complicates the engagement.' },
  { title: 'Stewardship', body: 'Your systems and budget are not ours to waste. We optimize for your long-term health.' },
];

// Founding members of Greenbriar Technology Group.
// NOTE: bios are short drafts — LinkedIn blocks automated access, so please
// review and expand these. To use a real portrait, replace the `photo` path
// with a committed image (see public/team/README.md). Titles intentionally
// omitted for now.
const members = [
  {
    name: 'Josef Schroeter',
    photo: '/team/josef-schroeter.svg',
    linkedin: 'https://www.linkedin.com/in/josefschroeter/',
    bio: 'Josef is a founding member of Greenbriar Technology Group, based in Boulder, Colorado, with a background in technology leadership and strategy. Full bio coming soon.',
  },
  {
    name: 'Mike Deskevich',
    photo: '/team/mike-deskevich.svg',
    linkedin: 'https://www.linkedin.com/in/michael-deskevich-2498b1279/',
    bio: 'Mike is a founding member of Greenbriar Technology Group, bringing hands-on engineering and technical depth to client work. Full bio coming soon.',
  },
  {
    name: 'Matthew Ball',
    photo: '/team/matthew-ball.svg',
    linkedin: 'https://www.linkedin.com/in/matthewvball/',
    bio: 'Matthew is a founding member of Greenbriar Technology Group — a senior software engineer with 20+ years building data and software systems, most recently large-scale ETL and data platforms. Based in Boulder, Colorado.',
  },
];
---

<Layout
  title="About"
  description={`About ${SITE.name} — a boutique technology consultancy founded in ${SITE.founded}, built on craft, candor, and stewardship.`}
>
  <PageHeader
    eyebrow="About"
    title="A boutique practice, by design."
    lead={`Founded in ${SITE.founded}, ${SITE.name} stays deliberately small so that senior people do the work — not just sell it.`}
  />

  <section class="section">
    <div class="container grid grid--2" style="align-items:start;">
      <div class="stack">
        <h2 class="mt-0">Why we exist</h2>
        <p>
          Most software problems are not really technology problems — they are
          clarity problems. Too many systems are built without a clear picture of
          what matters, then patched until no one dares touch them.
        </p>
        <p>
          We started Greenbriar to do the opposite: to bring seasoned judgment,
          plain communication, and real engineering to the teams that need it,
          without the bloat of a big consultancy.
        </p>
        <p>
          We are remote-first, senior-only, and intentionally selective about the
          work we take on — because focus is how small teams do outsized work.
        </p>
      </div>
      <ul class="values">
        {
          values.map((v) => (
            <li>
              <h3>{v.title}</h3>
              <p>{v.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section section--tight" id="team">
    <div class="container">
      <p class="eyebrow">The team</p>
      <h2>Who you'll actually work with</h2>
      <p>
        Greenbriar is a small, senior team — the people who scope your work are
        the people who do it. No hand-offs to junior staff you never met. Meet
        the founding members.
      </p>

      <ul class="team-grid">
        {
          members.map((m) => (
            <li class="member card">
              <img
                class="member__photo"
                src={m.photo}
                width="600"
                height="600"
                alt={`Portrait of ${m.name}`}
                loading="lazy"
                decoding="async"
              />
              <h3 class="member__name">{m.name}</h3>
              <p class="member__bio">{m.bio}</p>
              <a
                class="member__link"
                href={m.linkedin}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="prompt">&gt;</span> LinkedIn
                <span class="member__link-host">/in</span>
              </a>
            </li>
          ))
        }
      </ul>

      <p class="note">
        <span class="prompt">#</span> Draft bios and placeholder portraits — real
        photos and full bios coming soon.
      </p>
    </div>
  </section>

  <CallToAction />
</Layout>

<style>
  .values {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
  }

  .values li {
    border-left: 3px solid var(--mint);
    padding-left: 1.1rem;
  }

  .values h3 {
    margin-bottom: 0.25rem;
  }

  .values p {
    margin: 0;
    color: var(--ink-soft);
  }

  .team-grid {
    list-style: none;
    margin: 1.75rem 0 0;
    padding: 0;
    display: grid;
    gap: var(--gap);
  }

  @media (min-width: 48rem) {
    .team-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .member {
    display: flex;
    flex-direction: column;
  }

  .member__photo {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--rule);
    margin-bottom: 1.1rem;
    background: var(--ink-dark-surface);
  }

  .member__name {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .member__bio {
    color: var(--ink-soft);
    font-size: 0.95rem;
    flex: 1;
  }

  .member__link {
    align-self: start;
    margin-top: 0.5rem;
    font-weight: 700;
    font-size: 0.95rem;
    border-bottom: 1px solid transparent;
  }

  .member__link .prompt {
    color: var(--orange);
    font-weight: 700;
  }

  .member__link-host {
    color: var(--ink-faint);
    font-weight: 400;
  }

  .member__link:hover .member__link-host {
    color: inherit;
  }

  .note {
    color: var(--ink-faint);
    font-size: 0.9rem;
    margin-top: 2rem;
  }

  .note .prompt {
    font-weight: 700;
  }
</style>
