---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import CallToAction from '../components/CallToAction.astro';
import { SITE } from '../consts';

const values = [
  { title: 'Craft', body: 'We care about the details that users never see but always feel — the tests, the names, the edges.' },
  { title: 'Candor', body: 'We tell you what we actually think, early, even when it complicates the engagement.' },
  { title: 'Stewardship', body: 'Your systems and budget are not ours to waste. We optimize for your long-term health.' },
];

const team = [
  { name: 'A. Founder', role: 'Principal Consultant', bio: 'Two decades building and scaling systems across fintech and infrastructure. Still happiest in a terminal.' },
  { name: 'B. Partner', role: 'Cloud & Platform Lead', bio: 'Specializes in calm, operable platforms and teaching teams to run them.' },
  { name: 'C. Partner', role: 'Delivery Lead', bio: 'Turns ambiguous problems into shipped software, one thin slice at a time.' },
];
---

<Layout
  title="About"
  description={`About ${SITE.name} — a boutique technology consultancy founded in ${SITE.founded}, built on craft, candor, and stewardship.`}
>
  <PageHeader
    eyebrow="About"
    title="A boutique practice, by design."
    lead={`Founded in ${SITE.founded}, ${SITE.name} stays deliberately small so that senior people do the work — not just sell it.`}
  />

  <section class="section">
    <div class="container grid grid--2" style="align-items:start;">
      <div class="stack">
        <h2 class="mt-0">Why we exist</h2>
        <p>
          Most software problems are not really technology problems — they are
          clarity problems. Too many systems are built without a clear picture of
          what matters, then patched until no one dares touch them.
        </p>
        <p>
          We started Greenbriar to do the opposite: to bring seasoned judgment,
          plain communication, and real engineering to the teams that need it,
          without the bloat of a big consultancy.
        </p>
        <p>
          We are remote-first, senior-only, and intentionally selective about the
          work we take on — because focus is how small teams do outsized work.
        </p>
      </div>
      <ul class="values">
        {
          values.map((v) => (
            <li>
              <h3>{v.title}</h3>
              <p>{v.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <p class="eyebrow">The team</p>
      <h2>Who you'll actually work with</h2>
      <div class="grid grid--3" style="margin-top:2rem;">
        {
          team.map((t) => (
            <article class="card">
              <div class="avatar" aria-hidden="true">{t.name.charAt(0)}</div>
              <h3>{t.name}</h3>
              <p class="role">{t.role}</p>
              <p>{t.bio}</p>
            </article>
          ))
        }
      </div>
      <p class="note">
        <span class="prompt">#</span> Placeholder bios — real team profiles coming soon.
      </p>
    </div>
  </section>

  <CallToAction />
</Layout>

<style>
  .values {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
  }

  .values li {
    border-left: 3px solid var(--mint);
    padding-left: 1.1rem;
  }

  .values h3 {
    margin-bottom: 0.25rem;
  }

  .values p {
    margin: 0;
    color: var(--ink-soft);
  }

  .avatar {
    width: 3rem;
    height: 3rem;
    display: grid;
    place-items: center;
    font-size: 1.3rem;
    font-weight: 700;
    color: #06281d;
    background: var(--mint);
    border-radius: var(--radius);
    margin-bottom: 0.9rem;
  }

  .role {
    color: var(--orange);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }

  .note {
    color: var(--ink-faint);
    font-size: 0.9rem;
    margin-top: 1.5rem;
  }

  .prompt {
    color: var(--orange);
    font-weight: 700;
  }
</style>
